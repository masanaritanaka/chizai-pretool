{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://api.anthropic.com/**" }]
    },
    "shell:allow-open",
    "sql:default",
    "notification:default"
  ]
}
