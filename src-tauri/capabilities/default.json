{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        "https://www.j-platpat.inpit.go.jp/**",
        "https://console.anthropic.com/**",
        "https://www.notion.so/**"
      ]
    },
    "sql:default",
    "notification:default"
  ]
}
